            color:#666;
            margin-bottom:45px;
        }

        .services{
            display:flex;
            justify-content:center;
            flex-wrap:wrap;
            gap:25px;
        }

        .service-card{
            width:250px;
            background:white;
            padding:20px;
            border-radius:15px;
            box-shadow:0 4px 10px rgba(0,0,0,.1);
            transition:.3s;
        }

        .service-card:hover{
